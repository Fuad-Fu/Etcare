<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:elevation="2dp"
        android:background="@color/white">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/circle_purple_light"
            android:layout_marginEnd="12dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cancel"
                app:tint="@color/purple_primary" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/article_title_placeholder"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Big emoji / image placeholder -->
            <TextView
                android:id="@+id/tvDetailEmoji"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:gravity="center"
                android:text="@string/emoji_bone"
                android:textSize="60sp"
                android:background="@drawable/article_img_bg"
                android:layout_marginBottom="16dp" />

            <!-- Meta info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvDetailCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/health_tips_label"
                    android:textColor="@color/purple_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/lang_tag_bg"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvDetailReadTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/read_time_placeholder"
                    android:textColor="@color/nav_inactive"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Article body -->
            <TextView
                android:id="@+id/tvDetailBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/article_body_placeholder"
                android:textColor="@color/text_dark"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>