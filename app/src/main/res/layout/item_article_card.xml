<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/white"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvArticleEmoji"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:gravity="center"
            android:text="@string/emoji_bone"
            android:textSize="30sp"
            android:background="@drawable/article_img_bg" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvArticleTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/article_title_placeholder"
                android:textColor="@color/text_dark"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvArticleSnippet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/article_snippet_placeholder"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvArticleMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/article_meta_placeholder"
                android:textColor="@color/nav_inactive"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/read"
            android:textColor="@color/purple_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>