<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingBottom="30dp">

            <!-- Logo area -->
            <LinearLayout
                android:id="@+id/logoArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="48dp"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/et"
                        android:textColor="@color/purple_primary"
                        android:textSize="42sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.03" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/care"
                        android:textColor="@color/text_dark"
                        android:textSize="42sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.03" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/create_account_title"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Offline Indicator -->
            <TextView
                android:id="@+id/tvOfflineIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFE0E0"
                android:gravity="center"
                android:padding="6dp"
                android:text="@string/check_internet_msg"
                android:textColor="#D32F2F"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/logoArea" />

            <!-- Full name field -->
            <TextView
                android:id="@+id/labelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/full_name_label"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/tvOfflineIndicator"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/full_name_hint"
                android:textColorHint="@color/text_secondary"
                android:inputType="textPersonName"
                android:background="@drawable/edittext_bg"
                android:padding="14dp"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/labelName" />

            <!-- Email field -->
            <TextView
                android:id="@+id/labelEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email_label"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/etName"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/email_hint"
                android:textColorHint="@color/text_secondary"
                android:inputType="textEmailAddress"
                android:background="@drawable/edittext_bg"
                android:padding="14dp"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/labelEmail" />

            <!-- Password field -->
            <TextView
                android:id="@+id/labelPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/password_label"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/etEmail"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/password_hint"
                android:textColorHint="@color/text_secondary"
                android:inputType="textPassword"
                android:background="@drawable/edittext_bg"
                android:padding="14dp"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/labelPassword" />

            <!-- Confirm password field -->
            <TextView
                android:id="@+id/labelConfirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/confirm_password_label"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/etPassword"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/confirm_password_hint"
                android:textColorHint="@color/text_secondary"
                android:inputType="textPassword"
                android:background="@drawable/edittext_bg"
                android:padding="14dp"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/labelConfirm" />

            <!-- Sign Up button -->
            <Button
                android:id="@+id/btnSignUp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/signup_button"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/confirm_button_bg"
                app:backgroundTint="@color/purple_primary"
                android:paddingVertical="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginTop="24dp"
                app:cornerRadius="16dp"
                android:elevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/etConfirmPassword" />

            <!-- Login link -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/btnSignUp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/already_have_account_msg"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvLoginLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_link"
                    android:textColor="@color/purple_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/pbLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="@color/purple_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>